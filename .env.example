# =============================================================================
# MLOps Challenge — Environment Variables
# Copy this file to .env and adjust values before running any service.
#
#   cp .env.example .env
#
# All variables have sensible defaults in docker-compose.yml.
# Only set a variable here if you need to override the default.
# =============================================================================


# -----------------------------------------------------------------------------
# Gateway (NGINX)
# -----------------------------------------------------------------------------

# API key required in the X-API-Key header for all protected routes.
# Change this to a strong random value in any non-local environment.
NGINX_API_KEY=changeme-secret-key

# Host port mapped to the NGINX gateway container.
GATEWAY_PORT=80


# -----------------------------------------------------------------------------
# Inference API (FastAPI / Uvicorn)
# -----------------------------------------------------------------------------

# Host port mapped to the FastAPI service (direct access, bypasses gateway).
API_PORT=8000

# Root directory where training artifacts (SavedModel, metrics, config) are stored.
ARTIFACTS_DIR=artifacts

# run_id of the model to load at API startup.
# Leave empty to start the API without a loaded model (useful for testing).
DEFAULT_RUN_ID=


# -----------------------------------------------------------------------------
# Training (ml/train.py)
# -----------------------------------------------------------------------------

# Number of training epochs.
EPOCHS=10

# Training batch size.
BATCH_SIZE=32

# Minimum val_token_accuracy required for a run to pass the validation stage.
THRESHOLD=0.30

# Git commit SHA embedded in artifact metadata for traceability.
# Automatically set to the current HEAD by pipeline/run_pipeline.sh.
GIT_SHA=unknown


# -----------------------------------------------------------------------------
# Dataset Preparation (ml/prepare_dataset.py)
# -----------------------------------------------------------------------------

# Number of training samples to extract from the ParaCrawl dataset.
TRAIN_RECORDS=20000

# Number of validation samples to extract from the ParaCrawl dataset.
VAL_RECORDS=2000

# Output directory for the generated TFRecords.
OUTPUT_DIR=data/processed


# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------

# Host port mapped to the Prometheus container.
PROMETHEUS_PORT=9090


# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------

# Host port mapped to the Grafana container.
GRAFANA_PORT=3000

# Grafana admin username.
GRAFANA_USER=admin

# Grafana admin password. Change this before exposing Grafana publicly.
GRAFANA_PASSWORD=admin


# -----------------------------------------------------------------------------
# n8n Workflow Automation
# -----------------------------------------------------------------------------

# Host port mapped to the n8n container.
N8N_PORT=5678

# n8n basic auth username.
N8N_USER=admin

# n8n basic auth password. Change this before exposing n8n publicly.
N8N_PASSWORD=changeme

# Base URL n8n uses to construct webhook URLs shown in the UI.
# Must be reachable from wherever webhooks are triggered.
WEBHOOK_URL=http://localhost:5678


# -----------------------------------------------------------------------------
# Pipeline (pipeline/run_pipeline.sh)
# -----------------------------------------------------------------------------

# URL of the running inference API used by the deploy stage to call POST /reload.
# Set to the gateway URL if the API is behind NGINX.
API_URL=http://localhost:8000
