{
  "uid": "mlops-main",
  "title": "MLOps Challenge — Inference API",
  "description": "Monitoramento da Inference API de tradução PT→EN",
  "tags": ["mlops", "inference", "monitoring"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Status do Monitoramento",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Nota sobre coleta de métricas\n\nO endpoint `/metrics` da Inference API retorna **JSON customizado** (`application/json`), não o formato de exposição do Prometheus (`text/plain`).\n\n- **Painéis de valor instantâneo**: usam o datasource **Infinity**, que lê o JSON diretamente de `http://api:8000/metrics`.\n- **Time series**: requer que o Prometheus consiga fazer scrape. Para habilitar, adicione `prometheus_client` à API e substitua o endpoint `/metrics` pelo formato de exposição padrão."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "url": "http://api:8000/metrics",
          "source": "url",
          "format": "dataframe",
          "columns": [
            { "selector": "requests_total", "text": "Requests", "type": "number" }
          ]
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Translations",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "url": "http://api:8000/metrics",
          "source": "url",
          "format": "dataframe",
          "columns": [
            { "selector": "translations_total", "text": "Translations", "type": "number" }
          ]
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Errors",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "url": "http://api:8000/metrics",
          "source": "url",
          "format": "dataframe",
          "columns": [
            { "selector": "errors_total", "text": "Errors", "type": "number" }
          ]
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Rate %",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "url": "http://api:8000/metrics",
          "source": "url",
          "format": "dataframe",
          "columns": [
            { "selector": "errors_total",   "text": "errors_total",   "type": "number" },
            { "selector": "requests_total", "text": "requests_total", "type": "number" }
          ]
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "error_rate",
            "mode": "binary",
            "binary": { "left": "errors_total", "right": "requests_total", "operator": "/" }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Error Rate %",
            "mode": "binary",
            "binary": { "left": "error_rate", "right": "100", "operator": "*" }
          }
        },
        {
          "id": "organize",
          "options": { "excludeByName": { "errors_total": true, "requests_total": true, "error_rate": true } }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests Over Time",
      "description": "Rate de requisições por minuto. Requer Prometheus scrape funcional (ver nota acima).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(requests_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "requests/min — {{instance}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": {
          "query": "label_values(up{job=\"inference_api\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": []
}
